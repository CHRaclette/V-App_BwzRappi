<nsDrawer:RadSideDrawer
  id="sideDrawer"
  xmlns:nsDrawer="nativescript-ui-sidedrawer"
  loaded="onLoaded"
  class="ns-statusbar-transparent"
>
    <nsDrawer:RadSideDrawer.drawerTransition>
        <nsDrawer:SlideInOnTopTransition />
    </nsDrawer:RadSideDrawer.drawerTransition>

    <nsDrawer:RadSideDrawer.drawerContent>
        <GridLayout rows="auto, *" class="nt-drawer__content">
            <StackLayout class="nt-drawer__header">
                <Image class="nt-drawer__header-image fas t-36" src="font://&#xf2bd;" />
                <Label class="nt-drawer__header-brand" text="{{ userName }}" />
                <Label class="nt-drawer__header-footnote" text="{{ userFootnote }}" />
            </StackLayout>
            
            <ScrollView row="1">
                <StackLayout>
                    <GridLayout
            columns="auto, *"
            class="{{ 'nt-drawer__list-item' + (selectedPage === 'Dashboard' ? ' -selected': '') }}"
                    route="dashboard/dashboard-page"
            title="Dashboard"
            tap="onNavigationItemTap"
          >
                        <Label row="0" col="0" text="&#xf015;" class="nt-icon drawer-route-icon fas" />
                        <Label row="0" col="1" text="Dashboard" class="p-r-10 drawer-route-label" />
                    </GridLayout>

                    <GridLayout
            columns="auto, *"
            class="{{ 'nt-drawer__list-item' + (selectedPage === 'Public Key' ? ' -selected': '') }}"
                    route="public-key/public-key-page"
            title="Public Key"
            tap="onNavigationItemTap"
          >
                        <Label row="0" col="0" text="&#xf084;" class="nt-icon drawer-route-icon fas" />
                        <Label row="0" col="1" text="Public Key Lookup" class="p-r-10 drawer-route-label" />
                    </GridLayout>

                    <GridLayout
            columns="auto, *"
            class="{{ 'nt-drawer__list-item' + (selectedPage === 'Private Key' ? ' -selected': '') }}"
                    route="private-key/private-key-page"
            title="Private Key"
            tap="onNavigationItemTap"
          >
                        <Label row="0" col="0" text="&#xf1ea;" class="nt-icon drawer-route-icon far" />
                        <Label row="0" col="1" text="Private Key Lookup" class="p-r-10 drawer-route-label" />
                    </GridLayout>

                    <GridLayout
            columns="auto, *"
            class="{{ 'nt-drawer__list-item' + (selectedPage === 'Login' ? ' -selected': '') }}"
                    route="login/login-page"
            title="Login"
            tap="onNavigationItemTap"
          >
                        <Label row="0" col="0" text="&#xf2f6;" class="nt-icon drawer-route-icon fas" />
                        <Label row="0" col="1" text="Login" class="p-r-10 drawer-route-label" />
                    </GridLayout>

                    <StackLayout class="hr" />

                    <GridLayout
            columns="auto, *"
            class="{{ 'nt-drawer__list-item' + (selectedPage === 'Sign Up' ? ' -selected': '') }}"
                    route="signup/signup-page"
            title="Sign Up"
            tap="onNavigationItemTap"
          >
                        <Label row="0" col="0" text="&#xf013;" class="nt-icon drawer-route-icon fas" />
                        <Label row="0" col="1" text="Sign Up" class="p-r-10 drawer-route-label" />
                    </GridLayout>

                    <GridLayout
            columns="auto, *"
            class="nt-drawer__list-item drawer-logout-item"
            tap="onLogoutTap"
          >
                        <Label row="0" col="0" text="&#xf2f5;" class="nt-icon drawer-route-icon drawer-logout-icon fas" />
                        <Label row="0" col="1" text="Logout" class="p-r-10 drawer-route-label drawer-logout-label" />
                    </GridLayout>
                </StackLayout>
            </ScrollView>
        </GridLayout>
    </nsDrawer:RadSideDrawer.drawerContent>

    <nsDrawer:RadSideDrawer.mainContent>
        <Frame id="mainFrame" defaultPage="login/login-page" />
    </nsDrawer:RadSideDrawer.mainContent>
</nsDrawer:RadSideDrawer>
