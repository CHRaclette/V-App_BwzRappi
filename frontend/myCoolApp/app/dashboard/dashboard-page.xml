<Page navigatingTo="onNavigatingTo" xmlns="http://schemas.nativescript.org/tns.xsd">

    <ActionBar class="app-header">
        <NavigationButton visibility="hidden" />
        <GridLayout columns="50, *, 50" class="app-header-grid">
            <Label class="action-bar-title app-header-title" text="Dashboard" col="1" />
            <Label col="0" class="fas app-header-icon" text="&#xf0c9;" tap="onDrawerButtonTap" horizontalAlignment="center" verticalAlignment="center"/>
            <Label class="fas app-header-icon app-header-icon-secondary" col="2" text="&#xf021;" tap="onRefreshTap" horizontalAlignment="center" verticalAlignment="center" />
        </GridLayout>
    </ActionBar>

    <GridLayout rows="auto, *" columns="*">

        <!-- HEADER CARD -->
        <StackLayout row="0" class="card p-14">
            <Label class="h2" text="{{ reservationCountText }}" />
            <Button text="Reserve Room" tap="onOpenCreateModalTap" />
        </StackLayout>

        <!-- RESERVATIONS LIST -->
        <ListView row="1" items="{{ reservations }}" itemTap="onReservationItemTap" class="m-t-10">
            <ListView.itemTemplate>
                <StackLayout class="card p-16 m-y-8">

                    <Label class="h2" text="{{ locationLabel || 'No room' }}" />
                    <Label class="text-muted" text="{{ date + ' • ' + startDisplay + ' - ' + endDisplay }}" />

                    <StackLayout class="divider-soft"></StackLayout>

                    <StackLayout spacing="4">
                        <Label text="{{ 'Features: ' + (featuresLabel || '') }}" textWrap="true"/>
                        <Label text="{{ 'Comments: ' + (comments || '') }}" textWrap="true"/>
                        <Label text="{{ 'Participants: ' + (participants || '') }}" textWrap="true"/>
                    </StackLayout>

                    <StackLayout class="divider-muted"></StackLayout>

                    <StackLayout spacing="2">
                        <Label class="text-muted small" text="{{ 'Public: ' + (publicKey || '') }}" textWrap="true"/>
                        <Label class="text-muted small" text="{{ 'Private: ' + (privateKey || '') }}" textWrap="true"/>
                    </StackLayout>

                    <GridLayout columns="*, *" class="m-t-10">
                        <Button col="0" text="Edit" class="btn btn-primary m-r-5" tap="onEditReservationTap"/>
                        <Button col="1" text="Delete" class="btn btn-outline" tap="onDeleteReservationTap"/>
                    </GridLayout>

                </StackLayout>
            </ListView.itemTemplate>
        </ListView>

        <!-- MODAL -->
        <GridLayout rowSpan="2" class="dashboard-modal-overlay" visibility="{{ isReservationModalVisible ? 'visible' : 'collapsed' }}">
            <GridLayout class="dashboard-modal-sheet" rows="auto, *">

                <!-- HEADER -->
                <GridLayout columns="*, auto" class="p-16">
                    <Label col="0" class="h3" text="{{ isEditMode ? 'Edit Appointment' : 'Add Appointment' }}" />
                    <Button col="1" text="Close" tap="onCloseModalTap" />
                </GridLayout>

                <!-- FORM -->
                <ScrollView row="1">
                    <StackLayout class="p-16" spacing="10">

                        <TextField hint="Date (YYYY-MM-DD)" text="{{ editedDate }}" />
                        <TextField hint="Start Time (HH:MM:SS)" text="{{ editedStartTime }}" />
                        <TextField hint="End Time (HH:MM:SS)" text="{{ editedEndTime }}" />

                        <!-- ROOM PICKER -->
                        <Button text="{{ editedLocation || 'Select Room' }}" tap="onOpenRoomPicker" />

                        <Label text="{{ availabilityText }}" class="{{ availabilityClass }}" />

                        <TextField hint="Comment" text="{{ editedComment }}" />
                        <TextField hint="Participants" text="{{ editedParticipants }}" />

                        <GridLayout columns="*, *">
                            <Button col="0" text="Check" tap="onCheckAvailabilityTap" />
                            <Button col="1" text="{{ isEditMode ? 'Update' : 'Save' }}" tap="onSaveReservationTap" isEnabled="{{ roomIsAvailable }}" />
                        </GridLayout>

                    </StackLayout>
                </ScrollView>
            </GridLayout>
        </GridLayout>

    </GridLayout>
</Page>