<Page
    navigatingTo="onNavigatingTo"
    xmlns="http://schemas.nativescript.org/tns.xsd">

    <ActionBar class="app-header">
        <NavigationButton visibility="hidden"></NavigationButton>
        <GridLayout columns="50, *" class="app-header-grid">
            <Label class="action-bar-title app-header-title" text="Private Key Lookup" colSpan="2"/>
            <Label col="0" class="fas app-header-icon" text="&#xf0c9;" tap="onDrawerButtonTap" horizontalAlignment="center" verticalAlignment="center"/>
        </GridLayout>
    </ActionBar>

    <ScrollView>
        <StackLayout class="page__content p-20" spacing="12">
            <TextField hint="Enter private key" text="{{ privateKey }}" />
            <Button text="Fetch Reservation" tap="onSearchTap" />

            <Label class="h3" text="{{ resultTitle }}" />
            <StackLayout class="card p-10" visibility="{{ hasReservation ? 'visible' : 'collapsed' }}">
                <Label text="{{ reservation.locationLabel }}" />
                <Label text="{{ reservation.date }}" />
                <Label text="{{ reservation.startDisplay + ' - ' + reservation.endDisplay }}" />
                <Label text="{{ reservation.featuresLabel }}" textWrap="true" />
                <Label text="{{ reservation.comments }}" textWrap="true" />
                <Label text="{{ reservation.participants }}" textWrap="true" />
                <Label text="{{ 'Public key: ' + reservation.publicKey }}" textWrap="true" />
                <Label text="{{ 'Private key: ' + reservation.privateKey }}" textWrap="true" />
                <Button text="Edit Reservation" tap="onEditTap" />
                <Button class="btn btn-outline" text="Delete Reservation" tap="onDeleteTap" />
            </StackLayout>
        </StackLayout>
    </ScrollView>
</Page>
